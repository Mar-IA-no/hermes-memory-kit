# Core paths
HMK_WORKSPACE_ROOT=.
HMK_BASE_DIR=./agent-memory
HMK_DB_PATH=./agent-memory/library.db
HMK_VAULT_DIR=./wiki
HMK_ENV_FILE=.env
HMK_HERMES_HOME=~/.hermes

# Optional corpus / ranking hints
HMK_LIBRARY_CORPUS_PREFIX=
HMK_LEGACY_ROOT=
HMK_BOOTSTRAP_DOCS_JSON=
HMK_EXPORT_IDS=

# Embeddings
HERMES_EMBED_PROVIDER=nvidia
HERMES_EMBED_MODEL=
HERMES_EMBED_NVIDIA_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v1
HERMES_EMBED_GOOGLE_MODEL=gemini-embedding-001
HERMES_EMBED_GOOGLE_OUTPUT_DIMS=768
HERMES_EMBED_LOCAL_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Provider keys
NVIDIA_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
