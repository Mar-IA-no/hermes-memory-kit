# Hermes Agent gateway config — {{AGENT_NAME}}
# Generated by bootstrap_agent.py (hermes-memory-kit v3.0+).
# Paths are resolved from the sibling .env — do not hardcode absolute paths here.

model:
  default: {{DEFAULT_MODEL}}
  provider: {{DEFAULT_PROVIDER}}
  max_tokens: 1400

providers:
  nvidia:
    name: NVIDIA
    base_url: https://integrate.api.nvidia.com/v1
    key_env: NVIDIA_API_KEY
    api_mode: chat_completions
    default_model: nvidia/llama-3.3-nemotron-super-49b-v1
    models:
      nvidia/llama-3.3-nemotron-super-49b-v1: { context_length: 131072 }
      meta/llama-3.3-70b-instruct: { context_length: 131072 }
      moonshotai/kimi-k2.5: { context_length: 262144 }
      deepseek-ai/deepseek-v3.2: { context_length: 163840 }

terminal:
  backend: local
  cwd: .
  timeout: 180
  lifetime_seconds: 300

approvals:
  mode: manual
  timeout: 60

browser:
  inactivity_timeout: 120

compression:
  enabled: true
  threshold: 0.5
  target_ratio: 0.2
  protect_last_n: 20

memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 3000
  user_char_limit: 2200
  nudge_interval: 10
  flush_min_turns: 6

session_reset:
  mode: both
  idle_minutes: 1440
  at_hour: 4

group_sessions_per_user: true

streaming:
  enabled: false

skills:
  creation_nudge_interval: 50

agent:
  max_turns: 120
  verbose: false
  reasoning_effort: medium

# Plugin system
plugins:
  enabled:
    - dialogue-handoff
