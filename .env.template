# hermes-memory-kit v3.x — per-agent .env
# This file is loaded by scripts/hmk and by systemd (EnvironmentFile=).
# Paths below are RESOLVED AT BOOTSTRAP TIME to absolute paths because
# systemd EnvironmentFile= does NOT expand ${VAR} references — it reads
# values literally. Bootstrap replaces {{WORKSPACE_ROOT}} with an absolute
# path so `.env` stays systemd-friendly.

# === Agent identity ===
HMK_AGENT_NAME={{AGENT_NAME}}
HMK_WORKSPACE_ROOT={{WORKSPACE_ROOT}}

# === Memory paths (HMK_AGENT_MEMORY_BASE is canonical from v3.0) ===
HMK_HERMES_HOME={{WORKSPACE_ROOT}}/hermes-home
HMK_AGENT_MEMORY_BASE={{WORKSPACE_ROOT}}/agent-memory
HMK_DB_PATH={{WORKSPACE_ROOT}}/agent-memory/library.db
HMK_VAULT_DIR={{WORKSPACE_ROOT}}/wiki
HMK_ALWAYS_CONTEXT_PATH={{WORKSPACE_ROOT}}/agent-memory/state/ALWAYS-CONTEXT.md
HMK_DIALOGUE_HANDOFF_PATH={{WORKSPACE_ROOT}}/agent-memory/state/DIALOGUE-HANDOFF.md
HMK_SESSIONS_DIR={{WORKSPACE_ROOT}}/hermes-home/sessions

# === Legacy / compat aliases ===
# Hermes Agent upstream reads HERMES_HOME directly
HERMES_HOME={{WORKSPACE_ROOT}}/hermes-home
# Pre-v3 scripts read AGENT_MEMORY_BASE / HMK_BASE_DIR
AGENT_MEMORY_BASE={{WORKSPACE_ROOT}}/agent-memory
HMK_BASE_DIR={{WORKSPACE_ROOT}}/agent-memory

# === Embeddings (NVIDIA default, único proveedor soportado por defecto) ===
HERMES_EMBED_PROVIDER=nvidia
HERMES_EMBED_NVIDIA_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v1
HERMES_EMBED_LOCAL_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === LLM provider keys — fill in per agent ===
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Platform integrations — per-agent ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_REQUIRE_MENTION=false
DISCORD_IGNORE_NO_MENTION=false
HERMES_GATEWAY_TOKEN=

# === Budget guardrail (optional — enforce daily USD cap on LLM calls) ===
HMK_BUDGET_DAILY_USD=

# === Debug flags (optional) ===
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
